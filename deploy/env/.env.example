# Security notes:
# 1) Copy this file to deploy/env/.env and keep .env local only.
# 2) Replace placeholder passwords before running shared environments.

# ClickHouse
CLICKHOUSE_DB=aegis
CLICKHOUSE_USER=aegis_user
CLICKHOUSE_PASSWORD=change_me_clickhouse

# Optional: override if your compose project name differs.
CLICKHOUSE_VOLUME_NAME=deploy_clickhouse_data

# Kafka topics
KAFKA_TOPIC_EVENTS=siem.events
KAFKA_TOPIC_ALERTS=siem.alerts
KAFKA_TOPIC_EVENTS_DLQ=siem.events.dlq

# Grafana admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana
