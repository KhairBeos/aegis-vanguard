root = true

[*.{c,cpp,h,hpp,proto,py,sh,ps1,sql,md,yml,yaml,json,txt,cmake}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.py]
indent_size = 4

[CMakeLists.txt]
indent_size = 2
